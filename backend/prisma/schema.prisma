generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  phone      String?   @unique
  password   String
  name       String?
  role       UserRole? @default(USER)
  address    String?
  isActive   Boolean   @default(true)
  isVerified Boolean   @default(false)

  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  refreshTokenHash String?
  lastLoginAt      DateTime?

  vendorProfile VendorProfile?
  doctorProfile DoctorProfile?

  leads    Lead[]
  orders   Order[]
  reviews  Review[]
  listings Listing[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([role])
}

enum UserRole {
  USER
  VENDOR
  DOCTOR
  ADMIN
}

model VendorProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName String
  businessType VendorType
  description  String?
  address      String?
  isVerified   Boolean    @default(false)
  rating       Float      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VendorType {
  INDIVIDUAL
  COMPANY
  AGENCY
}

model DoctorProfile {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  doctorName         String
  nmcLicenseNumber   String             @unique
  specialization     MedicalServiceType
  verificationStatus VerificationStatus @default(PENDING)

  clinicAddress String?
  clinicName    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Listing {
  id          String          @id @default(cuid())

  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  price       Int?
  category    ListingCategory @default(VEHICLE)

  latitude  Float?
  longitude Float?

  images String[]

  isVerifiedDoctor Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle     Vehicle?
  job         Job?
  medical     MedicalAndDental?
  trades      TradesAndHomeRepair?
  rental      RentalAndRealEstate?
  agriculture AgricultureAndLivestock?
  secondhand  SecondHandGoods?
  foods       FoodsAndHomeDelivery?
  beauty      HairBeautyAndWellness?

  leads               Lead[]
  medicalappointments MedicalAppointment[]
  beautyAppointments  BeautyAppointment[]
  orders              Order[]
  reviews             Review[]

  @@index(userId)
  @@index([category])
  @@index([latitude, longitude])
}

enum ListingCategory {
  VEHICLE
  JOB
  MEDICAL
  TRADES
  RENTAL
  AGRICULTURE
  SECONDHAND
  FOODS
  BEAUTY
}

model Vehicle {
  id        String  @id @default(cuid())
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  type                     VehicleType
  brand                    String
  model                    String
  year                     Int
  km_driven                Int
  condition                VehicleCondition
  bluebook_status          BluebookStatus
  fuel_type                FuelType?
  details                  Json?
  ownership_transfer_ready Boolean @default(false)

  createdAt DateTime @default(now())
}

enum VehicleType {
  bike
  scooter
  car
  ev
  truck
  spare_parts
}

enum VehicleCondition {
  new
  used
  refurb
}

enum BluebookStatus {
  verified
  pending
  none
}

enum FuelType {
  petrol
  diesel
  electric
  hybrid
}

model Job {
  id String @id @default(cuid())

  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  role String

  salaryMin Int
  salaryMax Int
  payPeriod PayPeriod

  city      String
  skillTags String[]

  contractType ContractType

  isUrgent              Boolean @default(false)
  employerPhoneVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([isUrgent])
  @@index([contractType])
}

enum PayPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum ContractType {
  FULL_TIME
  PART_TIME
  GIG
  LABOUR
  DOMESTIC
}

model Lead {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  leadType  LeadType
  createdAt DateTime @default(now())

  status  LeadStatus @default(PENDING)
  message String?

  contactedAt DateTime?
  respondedAt DateTime?

  @@index([listingId])
  @@index([leadType])
  @@index([status])
  @@index([userId])
}

enum LeadType {
  CALL
  CHAT
  APPLY
}

enum LeadStatus {
  PENDING
  VIEWED
  SHORTLISTED
  INTERVIEWED
  REJECTED
  HIRED
  WITHDRAWN
}

model MedicalAndDental {
  id String @id @default(cuid())

  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  serviceType MedicalServiceType @default(GENERAL_MEDICINE)

  doctorName       String
  nmcLicenseNumber String

  verificationStatus VerificationStatus @default(PENDING)

  appointmentFee     Int
  homeVisitAvailable Boolean @default(false)
  clinicAddress      String
  city               String

  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  medicalAppointments   MedicalAppointment[]
  verificationDocuments VerificationDocument[]
  medicalSlots          MedicalSlot[]

  @@index([city])
  @@index([homeVisitAvailable])
  @@index([verificationStatus])
}

model MedicalAppointment {
  id String @id @default(cuid())

  medicalId String
  medical   MedicalAndDental @relation(fields: [medicalId], references: [id], onDelete: Cascade)

  slotId String
  slot   MedicalSlot @relation(fields: [slotId], references: [id])

  patientName String
  patientId   String?
  startTime   DateTime
  endTime     DateTime

  notes String?

  status    AppointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())

  Listing   Listing? @relation(fields: [listingId], references: [id])
  listingId String?

  @@index([status])
  @@index([medicalId])
}

model MedicalSlot {
  id String @id @default(cuid())

  medicalId String
  medical   MedicalAndDental @relation(fields: [medicalId], references: [id], onDelete: Cascade)

  day       WeekDay
  startTime String
  endTime   String

  isBooked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  medicalAppointments MedicalAppointment[]

  @@index([medicalId])
  @@index([day])
}

enum MedicalServiceType {
  DENTAL
  GENERAL_MEDICINE
  GYNECOLOGY
  ORTHOPEDIC
  DERMATOLOGY
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model VerificationDocument {
  id String @id @default(cuid())

  medicalId String
  medical   MedicalAndDental @relation(fields: [medicalId], references: [id], onDelete: Cascade)

  filePath String

  status          VerificationStatus @default(PENDING)
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([medicalId])
}

model TradesAndHomeRepair {
  id String @id @default(cuid())

  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  city               String
  ward               String?
  skillTags          String[]
  serviceAreaKm      Int
  calloutCharge      Int
  warrantyGiven      Boolean  @default(false)
  emergencyAvailable Boolean  @default(false)
  avgResponseHours   Float?   @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([city])
  @@index([emergencyAvailable])
  @@index([serviceAreaKm])
}

model RentalAndRealEstate {
  id String @id @default(cuid())

  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  propertyType PropertyType
  listingType  ListingType

  city String
  area String?
  ward String?

  address String?

  latitude  Float?
  longitude Float?

  monthlyRent   Int
  depositAmount Int

  bedrooms   Int?
  bathrooms  Int?
  squareFeet Int?

  furnished Boolean @default(false)

  parkingAvailable    Boolean @default(false)
  wifiAvailable       Boolean @default(false)
  waterIncluded       Boolean @default(false)
  electricityIncluded Boolean @default(false)

  petFriendly Boolean @default(false)

  availableFrom DateTime?

  isOwnerOrAgent OwnerType
  noBroker       Boolean   @default(false)

  nearbyLandmarks String[]

  rules String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([propertyType])
  @@index([listingType])
  @@index([furnished])
  @@index([isOwnerOrAgent])
  @@index([latitude, longitude])
}

enum PropertyType {
  ROOM
  FLAT
  APARTMENT
  HOUSE
  HOSTEL
  LAND
  SHUTTER
  OFFICE
}

enum ListingType {
  RENT
  SALE
}

enum OwnerType {
  OWNER
  AGENT
}

model AgricultureAndLivestock {
  id String @id @default(cuid())

  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  listingType AgricultureListingType

  district     String
  village      String?
  location     String
  pricePerUnit Int
  unit         UnitType

  organicCertified Boolean @default(false)
  organicVerified  Boolean @default(false)

  seasonalAvailability String?
  animalType           String?
  breed                String?
  age                  Int?
  healthVaccineStatus  HealthVaccineStatus?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([district])
  @@index([listingType])
  @@index([organicCertified])
  @@index([healthVaccineStatus])
}

enum AgricultureListingType {
  PRODUCE
  LIVESTOCK
  TOOL
  SEED
  FERTILIZER
  VET_SERVICE
  FARM_LABOUR
}

enum UnitType {
  KG
  LITRE
  PIECE
  HEAD
  BIGHA
}

enum HealthVaccineStatus {
  VACCINATED
  NOT_VACCINATED
  UNKNOWN
}

model SecondHandGoods {
  id        String  @id @default(cuid())
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  category  SecondHandCategory
  condition SecondHandCondition

  itemName     String
  price        Int
  isNegotiable Boolean       @default(false)
  photos       String[]
  city         String
  description  String?
  status       ListingStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  expiresAt    DateTime

  @@index([category])
  @@index([condition])
  @@index([city])
  @@index([price])
  @@index([status])
}

enum SecondHandCategory {
  FURNITURE
  APPLIANCES
  CLOTHING
  BOOKS
  BABY
  SPORTS
  INSTRUMENTS
  OTHER
}

enum SecondHandCondition {
  LIKE_NEW
  GOOD
  FAIR
  FOR_PARTS
}

enum ListingStatus {
  ACTIVE
  SOLD
  EXPIRED
}

model FoodsAndHomeDelivery {
  id        String  @id @default(cuid())
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  foodType  FoodType
  price     Int
  priceUnit PriceUnit

  deliveryRadiusKm      Int
  hygieneRating         Float     @default(0)
  subscriptionAvailable Boolean   @default(false)
  deliveryDays          WeekDay[]
  minOrderAmount        Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([foodType])
  @@index([deliveryRadiusKm])
}

model Review {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  reviewerName String?
  rating       Int
  comment      String?

  createdAt               DateTime               @default(now())
  HairBeautyAndWellness   HairBeautyAndWellness? @relation(fields: [hairBeautyAndWellnessId], references: [id])
  hairBeautyAndWellnessId String?

  @@index(userId)
  @@index([listingId])
}

model Order {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  quantity        Int
  totalPrice      Int
  deliveryDate    DateTime
  deliveryAddress String

  status       OrderStatus @default(PENDING)
  priceAtOrder Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index(userId)
  @@index([listingId])
  @@index([status])
  @@index([deliveryDate])
}

enum FoodType {
  TIFFIN
  BAKERY
  DAIRY
  MEAT
  ORGANIC
  HOME_COOK
  WHOLESALE
}

enum WeekDay {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum PriceUnit {
  PER_MEAL
  PER_KG
  PER_LITRE
  PER_PIECE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model HairBeautyAndWellness {
  id        String  @id @default(cuid())
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  serviceType BeautyServiceType

  price             Int
  priceStartingFrom Boolean  @default(false)
  homeVisit         Boolean  @default(false)
  portfolioUrls     String[]
  bridalAvailable   Boolean  @default(false)
  rating            Float    @default(0)
  city              String?

  beautySlots        BeautySlot[]
  beautyAppointments BeautyAppointment[]
  reviews            Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceType])
  @@index([homeVisit])
  @@index([bridalAvailable])
}

model BeautyAppointment {
  id String @id @default(cuid())

  beautyId String
  beauty   HairBeautyAndWellness @relation(fields: [beautyId], references: [id], onDelete: Cascade)

  slotId String
  slot   BeautySlot @relation(fields: [slotId], references: [id])

  customerName String
  customerId   String?
  startTime    DateTime
  endTime      DateTime

  notes String?

  status    AppointmentStatus @default(PENDING)
  createdAt DateTime          @default(now())
  Listing   Listing?          @relation(fields: [listingId], references: [id])
  listingId String?

  @@index([beautyId])
  @@index([status])
}

model BeautySlot {
  id String @id @default(cuid())

  beautyId String
  beauty   HairBeautyAndWellness @relation(fields: [beautyId], references: [id], onDelete: Cascade)

  day       WeekDay
  startTime String
  endTime   String

  isBooked  Boolean  @default(false)
  createdAt DateTime @default(now())

  beautyappointments BeautyAppointment[]

  @@index([beautyId])
  @@index([day])
}

enum BeautyServiceType {
  SALON
  BARBER
  MAKEUP_ARTIST
  SKINCARE
  SPA
  COSMETICS
  BRIDAL
}
