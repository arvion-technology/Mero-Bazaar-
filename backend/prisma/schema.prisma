generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id          String          @id @default(cuid())
  title       String
  description String?
  price       Int?
  category    ListingCategory @default(VEHICLE)

  latitude    Float?
  longitude   Float?

  images      String[]

  isVerifiedDoctor Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle     Vehicle?
  job         Job?
  medical     MedicalAndDental?
  trades      TradesAndHomeRepair?

  leads        Lead[]
  appointments Appointment[]

  @@index([category])
  @@index([latitude, longitude])
}

enum ListingCategory {
  VEHICLE
  JOB
  MEDICAL
  TRADES
}


model Vehicle {
  id                       String  @id @default(cuid())
  listingId                String  @unique
  listing                  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  type                     VehicleType
  brand                    String
  model                    String
  year                     Int
  km_driven                Int
  condition                VehicleCondition
  bluebook_status          BluebookStatus
  fuel_type                FuelType?
  ownership_transfer_ready Boolean @default(false)

  createdAt                DateTime @default(now())
}

enum VehicleType {
  bike
  scooter
  car
  ev
  truck
  spare_parts
}

enum VehicleCondition {
  new
  used
  refurb
}

enum BluebookStatus {
  verified
  pending
  none
}

enum FuelType {
  petrol
  diesel
  electric
  hybrid
}

model Job {
  id                    String @id @default(cuid())

  listingId             String @unique
  listing               Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  role                  String

  salaryMin             Int
  salaryMax             Int
  payPeriod             PayPeriod

  city                  String
  skillTags             String[]

  contractType          ContractType

  isUrgent              Boolean @default(false)
  employerPhoneVerified Boolean @default(false)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([city])
  @@index([isUrgent])
  @@index([contractType])
}

enum PayPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum ContractType {
  FULL_TIME
  PART_TIME
  GIG
  LABOUR
  DOMESTIC
}

model Lead {
  id              String   @id @default(cuid())
  listingId       String
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  leadType        LeadType
  createdAt       DateTime @default(now())

  contactedAt     DateTime?
  respondedAt     DateTime?

  @@index([listingId])
  @@index([leadType])
}

enum LeadType {
  CALL
  CHAT
  APPLY
}

model MedicalAndDental {
  id                      String  @id @default(cuid())

  listingId               String  @unique
  listing                 Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  doctorName              String
  specialty               String
  nmcLicenseNumber        String

  verificationStatus      VerificationStatus @default(PENDING)

  appointmentFee          Int
  availableSlots          Json

  homeVisitAvailable      Boolean @default(false)

  clinicAddress           String
  city                    String

  latitude                Float?
  longitude               Float?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  appointments            Appointment[]
  verificationDocuments   VerificationDocument[]

  @@index([city])
  @@index([specialty])
  @@index([homeVisitAvailable])
  @@index([verificationStatus])
}

model Appointment {
  id             String @id @default(cuid())

  listingId      String
  listing        Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  doctorId       String
  doctor         MedicalAndDental @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  patientId      String?
  patientName    String

  startTime      DateTime
  endTime        DateTime
  notes          String?

  status         AppointmentStatus @default(PENDING)
  createdAt      DateTime @default(now())

  @@index([doctorId])
  @@index([status])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model VerificationDocument {
  id                   String @id @default(cuid())

  medicalId            String
  medical              MedicalAndDental @relation(fields: [medicalId], references: [id], onDelete: Cascade)

  filePath             String

  status               VerificationStatus @default(PENDING)
  rejectionReason      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([medicalId])
}

model TradesAndHomeRepair {
  id                  String @id @default(cuid())

  listingId           String @unique
  listing             Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  city                String
  ward                String?
  skillTags           String[]
  serviceAreaKm       Int
  calloutCharge       Int
  warrantyGiven       Boolean @default(false)
  emergencyAvailable  Boolean @default(false)
  avgResponseHours    Float? @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([city])
  @@index([emergencyAvailable])
  @@index([serviceAreaKm])
}