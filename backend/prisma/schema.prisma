generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id          String          @id @default(cuid())
  title       String
  description String?
  price       Int?
  category    ListingCategory @default(VEHICLE)
  latitude    Float?
  longitude   Float?
  images      String[]
  createdAt   DateTime        @default(now())

  vehicle Vehicle?
  job     Job?
  medical MedicalAndDental?

  leads        Lead[]
  appointments Appointment[]
}

enum ListingCategory {
  VEHICLE
  JOB
  MEDICAL
}

model Vehicle {
  id        String  @id @default(cuid())
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  type                     VehicleType
  brand                    String
  model                    String
  year                     Int
  km_driven                Int
  condition                VehicleCondition
  bluebook_status          BluebookStatus
  fuel_type                FuelType?
  ownership_transfer_ready Boolean          @default(false)

  createdAt DateTime @default(now())
}

enum VehicleType {
  bike
  scooter
  car
  ev
  truck
  spare_parts
}

enum VehicleCondition {
  new
  used
  refurb
}

enum BluebookStatus {
  verified
  pending
  none
}

enum FuelType {
  petrol
  diesel
  electric
  hybrid
}

model Job {
  id String @id @default(cuid())

  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  role String

  salaryMin Int
  salaryMax Int
  payPeriod PayPeriod

  city      String
  skillTags String[]

  contractType ContractType

  isUrgent              Boolean @default(false)
  employerPhoneVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([isUrgent])
  @@index([contractType])
}

enum PayPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum ContractType {
  FULL_TIME
  PART_TIME
  GIG
  LABOUR
  DOMESTIC
}

model Lead {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  leadType  LeadType
  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([leadType])
}

enum LeadType {
  CALL
  CHAT
  APPLY
}

model MedicalAndDental {
  id        String  @id @default(cuid())
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  category         MedicalCategory
  doctorName       String
  speciality       String
  nmcLicenseNumber String
  isVerified       Boolean         @default(false)

  appointmentFee     Int
  availableSlots     Json
  homeVisitAvailable Boolean @default(false)
  clinicAddress      String
  city               String
  latitude           Float?
  longitude          Float?

  verification_doc_url String?
  verification_status  VerificationStatus @default(PENDING)
  nmcBadge             Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@index([city])
  @@index([speciality])
  @@index([homeVisitAvailable])
  @@index([isVerified])
}

model Appointment {
  id        String           @id @default(cuid())
  listingId String
  listing   Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    MedicalAndDental @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  start_time DateTime
  end_time   DateTime
  notes      String?

  status     AppointmentStatus @default(PENDING)
  created_at DateTime          @default(now())

  @@index([listingId])
  @@index([status])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum MedicalCategory {
  DENTAL
  GENERAL
  SPECIALIST
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}
